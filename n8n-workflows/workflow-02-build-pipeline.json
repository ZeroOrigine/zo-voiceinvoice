    {
      "parameters": {
        "jsCode": "// Semaphore check using n8n static data\nconst staticData = $getWorkflowStaticData('global');\nconst lockKey = 'BUILD_LOCK';\nconst lockTimeout = 30 * 60 * 1000; // 30 min timeout\n\nif (staticData[lockKey]) {\n  const lockTime = new Date(staticData[lockKey]).getTime();\n  const now = Date.now();\n  if (now - lockTime < lockTimeout) {\n    // Lock is active and not timed out\n    return []; // Stop execution\n  }\n  // Lock timed out, proceed\n}\n\n// Set lock\nstaticData[lockKey] = new Date().toISOString();\n\n// Take first approved project only\nconst items = $input.all();\nif (items.length === 0) return [];\n\nreturn [items[0]];"
      },
      "id": "semaphore-check",
      "name": "Semaphore Check (BUILD_LOCK)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [920, 300]
    },
