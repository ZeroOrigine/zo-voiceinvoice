      "parameters": {
        "jsCode": "// Collect all build outputs\nconst project = $('Category Dispatcher').first().json;\nconst schema = $('Builder Mind 1: Schema').first().json;\nconst apis = $('Builder Mind 2: APIs').first().json;\nconst core = $('Builder Mind 3: Core Feature').first().json;\nconst auth = $('Builder Mind 4: Auth + Payments').first().json;\nconst landing = $('Builder Mind 5: Landing Page').first().json;\n\nconst extractText = (resp) => {\n  if (resp.content && resp.content[0]) return resp.content[0].text;\n  return '';\n};\n\nreturn [{\n  json: {\n    ...project,\n    build_outputs: {\n      schema_sql: extractText(schema),\n      api_routes: extractText(apis),\n      core_components: extractText(core),\n      auth_payments: extractText(auth),\n      landing_page: extractText(landing)\n    },\n    build_flags: {\n      github_repo_created: false,\n      supabase_schema_created: false,\n      stripe_product_created: false,\n      netlify_site_created: false\n    }\n  }\n}];"
