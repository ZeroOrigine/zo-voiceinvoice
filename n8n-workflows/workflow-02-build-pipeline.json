      "parameters": {
        "jsCode": "const project = $input.first().json;\nconst category = project.category || 'ai-productivity';\n\n// Route to appropriate build template based on category\nconst categoryTemplates = {\n  'ai-writing': { template: 'zo-template-content', hasEditor: true },\n  'ai-analytics': { template: 'zo-template-dashboard', hasDashboard: true },\n  'ai-customer-service': { template: 'zo-template-chat', hasChat: true },\n  'ai-scheduling': { template: 'zo-template-calendar', hasCalendar: true },\n  'ai-content': { template: 'zo-template-content', hasEditor: true },\n  'ai-finance': { template: 'zo-template-dashboard', hasDashboard: true },\n  'ai-hr': { template: 'zo-template-forms', hasForms: true },\n  'ai-legal': { template: 'zo-template-documents', hasDocuments: true },\n  'ai-marketing': { template: 'zo-template-content', hasEditor: true },\n  'ai-sales': { template: 'zo-template-crm', hasCRM: true },\n  'ai-education': { template: 'zo-template-content', hasEditor: true },\n  'ai-healthcare': { template: 'zo-template-forms', hasForms: true },\n  'ai-real-estate': { template: 'zo-template-listings', hasListings: true },\n  'ai-travel': { template: 'zo-template-search', hasSearch: true },\n  'ai-food': { template: 'zo-template-marketplace', hasMarketplace: true },\n  'ai-fitness': { template: 'zo-template-tracker', hasTracker: true },\n  'ai-productivity': { template: 'zo-template-dashboard', hasDashboard: true },\n  'ai-security': { template: 'zo-template-dashboard', hasDashboard: true },\n  'ai-ecommerce': { template: 'zo-template-marketplace', hasMarketplace: true },\n  'ai-social': { template: 'zo-template-feed', hasFeed: true },\n  'ai-developer-tools': { template: 'zo-template-dashboard', hasDashboard: true },\n  'ai-design': { template: 'zo-template-canvas', hasCanvas: true }\n};\n\nconst config = categoryTemplates[category] || categoryTemplates['ai-productivity'];\n\nreturn [{\n  json: {\n    ...project,\n    build_template: config.template,\n    build_config: JSON.stringify(config),\n    repo_name: 'zo-' + (project.product_name || 'product').toLowerCase().replace(/[^a-z0-9]/g, '-').substring(0, 40),\n    subdomain: (project.product_name || 'product').toLowerCase().replace(/[^a-z0-9]/g, '-').substring(0, 30)\n  }\n}];"
      },
